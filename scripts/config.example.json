{
  "_comment": "TranscriptFlow example configuration. Copy to scripts/config.json and adjust for your environment.",
  "api": {
    "_comment": "OpenAI-compatible API configuration. LiteLLM, OpenRouter, vLLM, Ollama-compatible servers, and OpenAI all fit this interface.",
    "_key_warning": "Do NOT put your API key here. Set OPENAI_API_KEY or LITELLM_PROXY_KEY in your environment instead.",
    "base_url": "https://api.openai.com",
    "chat_completions_path": "/v1/chat/completions",
    "embeddings_path": "/v1/embeddings",
    "models_path": "/v1/models",
    "api_timeout": 60
  },
  "chunking": {
    "smart_merge_window_size": 5,
    "smart_merge_strong_pct": 0.02,
    "smart_merge_weak_pct": 0.05,
    "smart_merge_min_sentences": 8,
    "smart_merge_noise_drop_len": 2,
    "smart_merge_noise_weak_len": 3,
    "min_chunks": 2,
    "max_chunks": 200
  },
  "embedding": {
    "model": "text-embedding-3-large",
    "expected_dim": 3072,
    "batch_max_size": 64,
    "timeout": 60
  },
  "paths": {
    "output_dir": "./output",
    "db_path": "./lancedb",
    "master_file": "./examples/master_file_manifest.example.json",
    "data_dir": "./examples/srt",
    "backup_dir": "./output/lance_backup"
  },
  "summarization": {
    "models": [
      "gpt-4.1-mini"
    ],
    "participant_chunks": 3,
    "max_retries": 3,
    "concurrency": 5,
    "timeout_sec": 120
  },
  "tables": {
    "final_db": "psychology_kb"
  },
  "phase_concurrency": {
    "phase1_chunking": 1,
    "phase2_summarizing": 2,
    "phase3_embedding": 1,
    "phase4_db_insert": 1
  },
  "chunk_test": {
    "_comment": "chunk_test_runner.py 並行參數",
    "concurrency": 5
  },
  "srt_quality": {
    "_comment": "SRT 字幕品質檢查參數",
    "concurrency": 5,
    "models": ["gpt-4.1-mini", "gpt-4o-mini"]
  },
  "evaluation": {
    "_comment": "B+ chunk 品質評分與摘要忠實度使用的 LLM 模型",
    "chunk_models": ["gpt-4.1-mini", "gpt-4o-mini"],
    "fidelity_models": ["gpt-4.1-mini", "gpt-4o-mini"]
  },
  "watchdog": {
    "max_working_time_sec": 600
  },
  "monitoring": {
    "heartbeat_interval_sec": 300
  }
}
